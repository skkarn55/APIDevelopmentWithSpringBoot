<?xml version="1.0" encoding="UTF-8"?>
<hibernate-configuration xmlns="http://www.hibernate.org/xsd/orm/cfg">
    <session-factory>
        <property name="hibernate.connection.driver_class">oracle.jdbc.OracleDriver</property>
        <property name="hibernate.connection.url">jdbc:oracle:thin:@localhost:1521/XEPDB1</property>
        <property name="hibernate.connection.username">system</property>
        <property name="hibernate.connection.password">oracle</property>

        <property name="hibernate.dialect">org.hibernate.dialect.OracleDialect</property> <!--  Informs Hibernate which SQL dialect to use (e.g., MySQL, PostgreSQL, Oracle). This ensures Hibernate generates compatible SQL statements. -->
        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
    </session-factory>
</hibernate-configuration>
